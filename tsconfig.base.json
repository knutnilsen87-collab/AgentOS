{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "composite": true,
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@agentos/shared-types": ["packages/shared-types/src/index.ts"],
      "@agentos/policy-engine": ["packages/policy-engine/src/index.ts"],
      "@agentos/task-engine": ["packages/task-engine/src/index.ts"],
      "@agentos/project-scanner": ["packages/project-scanner/src/index.ts"],
      "@agentos/task-store": ["packages/task-store/src/index.ts"],
      "@agentos/status-bundle": ["packages/status-bundle/src/index.ts"]
    }
  }
}
