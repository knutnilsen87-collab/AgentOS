{
  "name": "@agentos/mission-kernel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mission kernel state machine, mission factory, agents, project scanner, audit log, and governance primitives.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  }
}
